# Databricks configuration
# Copy this file to dev.env or prod.env and fill in your values

# Databricks workspace URL (required)
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com

# Unity Catalog configuration (required)
CATALOG=your_catalog
SCHEMA=your_schema

# SQL Warehouse ID (required when DEPLOY_APP=true; used by the app and deploy-time permission grants)
# Find this in your workspace: SQL Warehouses > your warehouse > Connection Details
WAREHOUSE_ID=your_warehouse_id

# Set to "false" to skip app deployment (jobs-only mode)
DEPLOY_APP=true
